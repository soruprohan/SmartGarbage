<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/bg_card"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Row 1: Name + Status badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/tvBinName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Bin A1"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvBinStatus"
                android:layout_width="wrap_content"
                android:layout_height="22dp"
                android:background="@drawable/bg_status_badge"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:text="WORKING"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Row 2: Location -->
        <TextView
            android:id="@+id/tvBinLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Location"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="12dp"
            android:drawablePadding="4dp" />

        <!-- Row 3: Progress bar + percentage -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ProgressBar
                android:id="@+id/progressFillLevel"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="0dp"
                android:layout_height="8dp"
                android:layout_weight="1"
                android:max="100"
                android:progress="50"
                android:progressBackgroundTint="#E0E0E0"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/tvFillPercent"
                android:layout_width="38dp"
                android:layout_height="wrap_content"
                android:text="50%"
                android:textColor="@color/fill_medium"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="end" />
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
