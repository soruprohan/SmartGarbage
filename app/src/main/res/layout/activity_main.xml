<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Status Banner -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1A4CAF50"
            android:padding="16dp"
            android:text="✅ Phase 2 Verification"
            android:textColor="#4CAF50"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="32dp" />

        <!-- Driver Info Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bg_card"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DRIVER INFO (from TokenManager)"
                android:textColor="@color/text_hint"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tvDriverName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Name: —"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvDriverEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email: —"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvDriverId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ID: —"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- Token Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bg_card"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="JWT TOKEN (from TokenManager)"
                android:textColor="@color/text_hint"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tvTokenStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Checking…"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvTokenPreview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- Session Persistence Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bg_card"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SESSION PERSISTENCE TEST"
                android:textColor="@color/text_hint"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1. Press Home (don't swipe away)\n2. Re-open the app\n3. Should land here directly — NOT on Login"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.5" />
        </LinearLayout>

        <!-- Logout Button -->
        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Test Logout"
            android:textSize="15sp"
            android:backgroundTint="#C62828"
            android:textColor="@color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Logout should clear token and return to Login screen"
            android:textColor="@color/text_hint"
            android:textSize="12sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="40dp"
            android:gravity="center" />

    </LinearLayout>
</ScrollView>